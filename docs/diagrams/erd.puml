@startuml

!theme plain
hide circle
skinparam linetype ortho

' Entities
entity "User" as User {
  *id : number <<generated>>
  --
  *email : text
  *password : text
  *roleId : number
  full_name : text
}

entity "Role" as Role {
  *id : number <<generated>>
  --
  *name : text
  description : text
}

entity "Permission" as Permission {
  *id : number <<generated>>
  --
  *path : text
  *method : text
  module : text
}

entity "Shop" as Shop {
  *shopid : number <<FK>>
  --
  *name : text
  *slug : text
  status : text
}

entity "Product" as Product {
  *id : number <<generated>>
  --
  *name : text
  *base_price : number
  *shopId : number <<FK>>
  *brandId : number <<FK>>
}

entity "SKU" as SKU {
  *id : number <<generated>>
  --
  *skuCode : text
  *productId : number <<FK>>
  price : number
  stock : number
}

entity "Category" as Category {
  *id : number <<generated>>
  --
  *name : text
  parentCategoryId : number <<FK>>
}

entity "Order" as Order {
  *id : number <<generated>>
  --
  *userId : number <<FK>>
  *shopId : number <<FK>>
  *total : number
  status : text
}

entity "FlashSale" as FlashSale {
  *id : number <<generated>>
  --
  *name : text
  startAt : datetime
  endAt : datetime
}

entity "FlashSaleItem" as FlashSaleItem {
  *id : number <<generated>>
  --
  *flashSaleId : number <<FK>>
  *skuId : number <<FK>>
  flash_price : number
}

entity "Review" as Review {
  *id : number <<generated>>
  --
  *orderItemId : number
  rating : number
  content : text
}

entity "CartItem" as CartItem {
  *id : number <<generated>>
  --
  *userId : number <<FK>>
  *skuId : number <<FK>>
  quantity : number
}

entity "AddressShip" as AddressShip {
  *id : number <<generated>>
  --
  *userId : number <<FK>>
  address : text
  city : text
}

entity "Brand" as Brand {
  *id : number <<generated>>
  --
  *name : text
}

entity "Voucher" as Voucher {
  *id : number <<generated>>
  --
  *code : text
  discountId : number <<FK>>
}

entity "Discount" as Discount {
  *id : number <<generated>>
  --
  *name : text
  value : number
}

' Relationships
User ||..|| Role : "has role"
Role }|..|{ Permission : "has permissions"
User ||--|| Shop : "owns"
Shop ||--|{ Product : "sells"
Product }|--|| Brand : "belongs to"
Product }|--|{ Category : "categorized in"
Category |o--o{ Category : "parent/child"
Product ||--|{ SKU : "has variants"
SKU }|--|| FlashSaleItem : "in flash sale"
FlashSale ||--|{ FlashSaleItem : "contains"
User ||--|{ Order : "places"
Shop ||--|{ Order : "receives"
Order ||--|{ SKU : "contains items"
User ||--|{ Review : "writes"
Product ||--|{ Review : "has reviews"
User ||--|{ CartItem : "has"
CartItem }|--|| SKU : "contains"
User ||--|{ AddressShip : "has addresses"
Voucher }|--|| Discount : "uses"
Order }|--|| Voucher : "applies"

@enduml